# Coloque aqui a sua chave de API do Google Gemini
# Você pode conseguir uma em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui_sem_aspas

# Configurações do JWT (Segurança da API)
# JWT_SECRET=sua_chave_secreta_aleatoria_e_forte_aqui (ex: chave hex de 32 bytes)
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# PASSWORD_PEPPER=seu_pepper_secreto_aleatorio_e_forte_aqui (ex: chave hex de 32 bytes)
